{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "Jwt": {
    "Issuer": "MiniECommerceAuth",
    "Audience": "MiniECommerceServices",
    "SigningKey": ""
  },

  "ReverseProxy": {
    "Routes": {
      "products-read-route": {
        "ClusterId": "products-cluster",
        "Match": { "Path": "/api/products/{**catch-all}", "Methods": [ "GET" ] }
      },
      "products-write-route": {
        "ClusterId": "products-cluster",
        "AuthorizationPolicy": "RequireAuth",
        "Match": { "Path": "/api/products/{**catch-all}", "Methods": [ "POST", "PUT", "DELETE" ] }
      },
      "orders-route": {
        "ClusterId": "orders-cluster",
        "AuthorizationPolicy": "RequireAuth",
        "Match": { "Path": "/api/orders/{**catch-all}" }
      },
      "users-route": {
        "ClusterId": "users-cluster",
        "AuthorizationPolicy": "RequireAuth",
        "Match": { "Path": "/api/users/{**catch-all}" }
      },
      "auth-route": {
        "ClusterId": "users-cluster",
        "Match": { "Path": "/api/auth/{**catch-all}" }
      }
    },
    "Clusters": {
      "products-cluster": {
        "Destinations": {
          "destination1": { "Address": "http://localhost:5001/" }
        }
      },
      "orders-cluster": {
        "Destinations": {
          "destination1": { "Address": "http://localhost:5002/" }
        }
      },
      "users-cluster": {
        "Destinations": {
          "destination1": { "Address": "http://localhost:5003/" }
        }
      }
    }
  }
}